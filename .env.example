DATABASE_URL="postgresql://postgres:postgres@localhost:5433/helpdesk_lite"
AUTH_SECRET="generate-a-random-secret-for-production"

# AI provider: auto | ollama | mock
AI_PROVIDER="auto"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen2.5:7b"
OLLAMA_TIMEOUT_MS="120000"
OLLAMA_MAX_RETRIES="2"
OLLAMA_RETRY_DELAY_MS="250"

# Email notifications (optional — skipped when unset)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="HelpDesk Lite <noreply@helpdesk.local>"
NOTIFY_EMAIL_TO="staff@helpdesk.local"

# Webhook notifications (optional — skipped when WEBHOOK_URL is empty)
WEBHOOK_URL=""
WEBHOOK_SECRET=""
WEBHOOK_TIMEOUT_MS="10000"
