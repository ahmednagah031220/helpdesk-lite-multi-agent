DATABASE_URL="postgresql://postgres:postgres@localhost:5433/helpdesk_lite"
AUTH_SECRET="generate-a-random-secret-for-production"

# Default organization for SSO joiners
DEFAULT_ORG_SLUG="acme"
DEFAULT_ORG_NAME="Acme Corp"

# Optional Google SSO (shows button on /login when both are set)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI provider: auto | ollama | mock
AI_PROVIDER="auto"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="qwen2.5:7b"
OLLAMA_TIMEOUT_MS="120000"
OLLAMA_MAX_RETRIES="2"
OLLAMA_RETRY_DELAY_MS="250"

# Embeddings: auto (ollama then local) | local
EMBEDDING_PROVIDER="local"
EMBEDDING_MODEL="nomic-embed-text"

# Durable agent queue (BullMQ + Redis). Set AGENT_QUEUE=off to force inline after().
REDIS_URL="redis://127.0.0.1:6379"
AGENT_QUEUE="on"
AGENT_WORKER_CONCURRENCY="2"

# Email notifications — use Mailpit locally (docker compose service `mailpit`)
SMTP_HOST="127.0.0.1"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="HelpDesk Lite <noreply@helpdesk.local>"
NOTIFY_EMAIL_TO="staff@helpdesk.local,manager@helpdesk.local"

# Webhook — local echo service
WEBHOOK_URL="http://127.0.0.1:8089/"
WEBHOOK_SECRET="helpdesk-dev-webhook-secret"
WEBHOOK_TIMEOUT_MS="10000"
